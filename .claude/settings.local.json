{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash(*)",
      "WebSearch",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Bash(*rm -rf*)",
      "Bash(*Remove-Item -Recurse -Force /*)",
      "Bash(*sudo*)",
      "Bash(*git push*)",
      "Bash(*git remote*)",
      "Bash(*cargo publish*)",
      "Bash(*del /s /q*)"
    ]
  }
}
