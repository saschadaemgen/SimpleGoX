{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash(*)"
    ],
    "deny": [
      "Bash(*rm -rf*)",
      "Bash(*Remove-Item -Recurse -Force /*)",
      "Bash(*sudo*)",
      "Bash(*git push*)",
      "Bash(*git remote*)",
      "Bash(*cargo publish*)",
      "Bash(*del /s /q*)"
    ]
  }
}
